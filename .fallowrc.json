{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "cspell",
    "fallow",
    "lefthook",
    "markdownlint-cli2",
    "oxfmt",
    "oxlint",
    "oxlint-tsgolint"
  ],
  "duplicates": { "ignore": ["tests/**"] },
  "rules": { "duplicate-exports": "off" }
}
