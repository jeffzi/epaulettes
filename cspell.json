{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "files": ["**/*.{ts,tsx,mts,cts,md}"],
  "words": ["epaulettes", "jeffzi"],
  "ignorePaths": [
    ".planning",
    ".research",
    "*.tsbuildinfo",
    "CHANGELOG.md",
    "coverage",
    "dist",
    "node_modules",
    "package-lock.json"
  ]
}
